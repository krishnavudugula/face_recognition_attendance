# Face++ (Megvii) Configuration
# Get these from https://www.faceplusplus.com after creating account
# Free tier: 1,000 API calls/day (30,000/month)
FACEPP_API_KEY=your_api_key_here
FACEPP_API_SECRET=your_api_secret_here
FACEPP_FACESET_ID=attendance-system

# Database Configuration
# Use SQLite for local development (default: sqlite:///face_attendance.db)
# Use PostgreSQL for production (e.g., on Render)
DATABASE_URL=sqlite:///face_attendance.db

# Optional: For production deployment on Render
# DATABASE_URL=postgresql://user:password@host:port/dbname

# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=False

# Server Configuration (optional)
# PORT=8000
# WORKERS=4
