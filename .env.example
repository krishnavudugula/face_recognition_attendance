# Environment
FLASK_ENV=production

# Face++ Credentials (get from Face++ dashboard)
FACEPP_API_KEY=your_api_key_here
FACEPP_API_SECRET=your_api_secret_here
FACEPP_FACESET_ID=attendance-system

# Database (SQLite on Railway)
SQLALCHEMY_DATABASE_URI=sqlite:///attendance.db

# Firebase (optional, for push notifications)
FIREBASE_SERVICE_ACCOUNT_KEY=firebase-key.json

# Server
PORT=5000
